# ============================================================================
# DATA-SHIELD SPECIFIC — SENSITIVE DATA
# ============================================================================

# Vault & Encrypted Files
*.ds-vault                          # Encrypted files created by Data-Shield Vault
.ds-vault/

# Database files (contain sensitive metadata)
src/datashield/storage/*.db         # SQLite databases with findings
src/datashield/storage/*.db-shm     # SQLite shared memory
src/datashield/storage/*.db-wal     # SQLite write-ahead log
datashield.db
datashield.db-shm
datashield.db-wal

# Audit & Log Files
datashield_audit.log                # Audit trail with findings
datashield_audit.*.log
datashield_*.log
logs/
*.log

# Config Files with Secrets
.env.local
.env.*.local
*.config.local
src/datashield/config/*.json.local  # User-specific config

# Master Key / Credentials Cache (should never be committed)
.master_key
.master_key.encrypted
vault_password.txt
vault_password.encrypted

# ============================================================================
# WINDOWS SPECIFIC
# ============================================================================
*.exe
*.msi
*.dll
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
ehthumbs.db

# ============================================================================
