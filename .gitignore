# ============================================================================
# BUILD & DISTRIBUTION
# ============================================================================
build/
dist/
*.egg-info/
.eggs/
wheels/
*.whl

# ============================================================================
# CI/CD (but commit workflow files themselves)
# ============================================================================
.github/workflows/*.tmp
artifacts/
test-results/

# ============================================================================
# LOCAL DEVELOPMENT
# ============================================================================
.vscode/launch.json            # User-specific VS Code launch config
.vscode/settings.json          # User-specific VS Code settings
.idea/runConfigurations/       # User-specific IntelliJ run configs
local_test_files/              # Temp test data
scratch.py                     # Scratch work files
*.scratch.*

# ============================================================================
# NEVER COMMIT ACTUAL CREDENTIALS OR TEST DATA WITH REAL SECRETS
# ============================================================================
# (These are fail-safes; never put real secrets in version control)

test_credentials.txt
real_api_key.txt
AWS_SECRET_KEY
GITHUB_TOKEN
OPENAI_KEY

# ============================================================================
# PERFORMANCE & PROFILING
# ============================================================================
*.prof
*.pstats
performance_log.txt
benchmark_results.json

# ============================================================================
# DOCUMENTATION BUILD ARTIFACTS
# ============================================================================
docs/_build/
docs/.build/
site/

# ============================================================================
# ALLOW (whitelist overrides)
# ============================================================================
# Keep these patterns out of exclusion:
!.github/workflows/*.yml        # CI/CD workflows
!.gitkeep                        # Empty directory markers
!src/datashield/patterns/yara_rules/*.yar  # YARA rules (legitimate patterns)
!src/datashield/gui/resources/  # GUI resources (safe)

# ============================================================================
# NOTES FOR CONTRIBUTORS
# ============================================================================
# If you need to add sensitive files locally:
# 1. Use .env.local for environment variables (gitignored)
# 2. Use .gitkeep in empty directories that should exist
# 3. NEVER commit real credentials, API keys, or passwords
# 4. Use placeholder values in configs, document in README
# 5. Test your .gitignore locally: git check-ignore -v <file>

# Report if you see sensitive data accidentally committed:
# git log --all -S'AKIA' (find AWS keys)
# git log --all -S'sk-' (find OpenAI keys)
